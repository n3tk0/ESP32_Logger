{
  "version": 1,
  "mode": "legacy",
  "sleep_mode": "deep",

  "sensors": [
    {
      "id": "flow_main",
      "type": "yfs201",
      "enabled": true,
      "interface": "pulse",
      "pin": 21,
      "pulses_per_liter": 450.0,
      "calibration": 1.0,
      "read_interval_ms": 1000
    },
    {
      "id": "env_indoor",
      "type": "bme280",
      "enabled": false,
      "interface": "i2c",
      "sda": 6,
      "scl": 7,
      "address": 118,
      "read_interval_ms": 10000
    },
    {
      "id": "dust_outdoor",
      "type": "sds011",
      "enabled": false,
      "interface": "uart",
      "uart_rx": 20,
      "uart_tx": -1,
      "baud": 9600,
      "work_period_min": 1
    },
    {
      "id": "pm_outdoor",
      "type": "pms5003",
      "enabled": false,
      "interface": "uart",
      "uart_rx": 20,
      "uart_tx": -1,
      "baud": 9600,
      "read_interval_ms": 30000
    },
    {
      "id": "voc_indoor",
      "type": "ens160",
      "enabled": false,
      "interface": "i2c",
      "sda": 6,
      "scl": 7,
      "address": 82,
      "read_interval_ms": 30000
    },
    {
      "id": "rain_gauge",
      "type": "rain",
      "enabled": false,
      "interface": "pulse",
      "pin": 9,
      "mm_per_pulse": 0.2794,
      "read_interval_ms": 60000
    },
    {
      "id": "wind_speed",
      "type": "wind",
      "enabled": false,
      "interface": "pulse",
      "pin": 8,
      "pulses_per_rev": 1,
      "meters_per_rev": 0.5,
      "sample_window_ms": 3000
    }
  ],

  "aggregation": {
    "default_mode": "lttb",
    "default_bucket_min": 5,
    "max_points": 500,
    "raw_retention_days": 7,
    "ring_buffer_size": 500
  },

  "export": {
    "mqtt": {
      "enabled": false,
      "broker": "192.168.1.100",
      "port": 1883,
      "topic_prefix": "waterlogger",
      "client_id": "",
      "username": "",
      "password": "",
      "qos": 0,
      "retain": false,
      "interval_ms": 60000
    },
    "http": {
      "enabled": false,
      "url": "",
      "method": "POST",
      "headers": {},
      "interval_ms": 60000
    },
    "sensor_community": {
      "enabled": false,
      "interval_ms": 145000
    },
    "opensensemap": {
      "enabled": false,
      "box_id": "",
      "access_token": "",
      "sensor_ids": {
        "temperature": "",
        "humidity": "",
        "pressure": "",
        "pm25": "",
        "pm10": ""
      }
    }
  },

  "storage": {
    "log_dir": "/logs",
    "rotate_daily": true,
    "max_file_size_kb": 512,
    "cloud_only": false
  }
}
